// ================= DEVICE API FUNCTIONS =================

void loadDeviceCredentialsFromEEPROM() {
  Serial.println("\n[DEVICE API] Loading credentials from EEPROM...");
  
  EEPROM.get(EEPROM_DEVICE_SERIAL_ADDR, DEVICE_SERIAL);
  EEPROM.get(EEPROM_DEVICE_API_KEY_ADDR, DEVICE_API_KEY);
  
  // Check if credentials are valid (not empty/default)
  if (strlen(DEVICE_SERIAL) > 0 && strlen(DEVICE_API_KEY) > 0) {
    deviceRegistered = true;
    Serial.printf("[DEVICE API] Device Serial: %s\n", DEVICE_SERIAL);
    Serial.println("[DEVICE API] API Key loaded (hidden for security)");
  } else {
    deviceRegistered = false;
    Serial.println("[DEVICE API] No stored credentials found - device needs registration");
  }
}

void saveDeviceCredentialsToEEPROM() {
  Serial.println("[DEVICE API] Saving credentials to EEPROM...");
  
  EEPROM.put(EEPROM_DEVICE_SERIAL_ADDR, DEVICE_SERIAL);
  EEPROM.put(EEPROM_DEVICE_API_KEY_ADDR, DEVICE_API_KEY);
  
  if (EEPROM.commit()) {
    Serial.printf("[DEVICE API] Credentials saved - Serial: %s\n", DEVICE_SERIAL);
    deviceRegistered = true;
  } else {
    Serial.println("[DEVICE API] ERROR: Failed to save credentials!");
    deviceRegistered = false;
  }
}

void registerDevice() {
  if (!wifiConnected) {
    Serial.println("[DEVICE API] ERROR: WiFi not connected - cannot register");
    return;
  }
  
  Serial.println("\n[DEVICE API] Registering device with backend...");
  
  // Get ESP32 MAC address as chip ID
  uint8_t chipId[6];
  esp_efuse_mac_get_default(chipId);
  char chipIdStr[18];
  sprintf(chipIdStr, "%02X%02X%02X%02X%02X%02X", 
          chipId[0], chipId[1], chipId[2], chipId[3], chipId[4], chipId[5]);
  
  HTTPClient http;
  http.begin(REGISTER_URL);
  http.addHeader("Content-Type", "application/json");
  http.setTimeout(5000);
  
  StaticJsonDocument<256> doc;
  doc["chipId"] = chipIdStr;
  doc["deviceType"] = "poultry-monitor";
  doc["firmwareVersion"] = "v5.0";
  
  String payload;
  serializeJson(doc, payload);
  
  Serial.printf("[DEVICE API] Sending registration: %s\n", payload.c_str());
  int httpResponseCode = http.POST(payload);
  
  if (httpResponseCode == 200 || httpResponseCode == 201) {
    String response = http.getString();
    Serial.printf("[DEVICE API] Registration response: %s\n", response.c_str());
    
    StaticJsonDocument<512> responseDoc;
    DeserializationError error = deserializeJson(responseDoc, response);
    
    if (!error) {
      if (responseDoc.containsKey("deviceSerial") && responseDoc.containsKey("apiKey")) {
        strncpy(DEVICE_SERIAL, responseDoc["deviceSerial"].as<const char*>(), EEPROM_SERIAL_LENGTH - 1);
        strncpy(DEVICE_API_KEY, responseDoc["apiKey"].as<const char*>(), EEPROM_API_KEY_LENGTH - 1);
        saveDeviceCredentialsToEEPROM();
        
        Serial.printf("[DEVICE API] Device registered successfully!\n");
        Serial.printf("[DEVICE API] Serial: %s\n", DEVICE_SERIAL);
        
        sendGSMAlert("Device registered - Serial: " + String(DEVICE_SERIAL), "INFO");
      }
    }
  } else {
    Serial.printf("[DEVICE API] Registration failed - HTTP %d\n", httpResponseCode);
    String response = http.getString();
    Serial.printf("[DEVICE API] Error response: %s\n", response.c_str());
  }
  
  http.end();
}

void updateDeviceStatus() {
  if (!wifiConnected || strlen(DEVICE_SERIAL) == 0 || strlen(DEVICE_API_KEY) == 0) {
    return;
  }
  
  HTTPClient http;
  http.begin(STATUS_URL);
  http.addHeader("Content-Type", "application/json");
  http.addHeader("x-device-serial", DEVICE_SERIAL);
  http.addHeader("x-api-key", DEVICE_API_KEY);
  http.setTimeout(5000);
  
  StaticJsonDocument<256> doc;
  doc["status"] = "active";
  doc["uptime"] = (millis() / 1000);
  doc["heaterStatus"] = digitalRead(HEATER_RELAY) ? "ON" : "OFF";
  doc["exhaustStatus"] = digitalRead(EXHAUST_RELAY) ? "ON" : "OFF";
  doc["powerSource"] = (solarVoltage >= SOLAR_THRESHOLD_VOLTAGE) ? "SOLAR" : "GRID";
  
  String payload;
  serializeJson(doc, payload);
  
  int httpResponseCode = http.POST(payload);
  if (httpResponseCode != 200 && httpResponseCode != 201) {
    Serial.printf("[DEVICE API] Status update failed - HTTP %d\n", httpResponseCode);
  }
  
  http.end();
}

void sendSensorDataToAPI() {
  if (!wifiConnected || strlen(DEVICE_SERIAL) == 0 || strlen(DEVICE_API_KEY) == 0) {
    return;
  }
  
  HTTPClient http;
  http.begin(STREAM_URL);
  http.addHeader("Content-Type", "application/json");
  http.addHeader("x-device-serial", DEVICE_SERIAL);
  http.addHeader("x-api-key", DEVICE_API_KEY);
  http.setTimeout(5000);
  
  StaticJsonDocument<512> doc;
  doc["deviceSerial"] = DEVICE_SERIAL;
  doc["timestamp"] = millis();
  
  JsonObject environment = doc.createNestedObject("environment");
  environment["temperatureDHT"] = temperatureDHT;
  environment["temperatureDS18B20"] = temperatureDS18B20;
  environment["humidity"] = humidity;
  environment["co2"] = ppmCO2;
  environment["ammonia"] = ppmNH3;
  environment["lpg"] = ppmLPG;
  environment["lightInside"] = lightPercent;
  
  JsonObject power = doc.createNestedObject("power");
  power["solarVoltage"] = solarVoltage;
  power["solarCurrent"] = solarCurrent_mA;
  power["solarPower"] = solarPower_W;
  power["loadPower"] = loadPower_W;
  power["powerSource"] = (solarVoltage >= SOLAR_THRESHOLD_VOLTAGE) ? "SOLAR" : "GRID";
  
  JsonObject control = doc.createNestedObject("control");
  control["heater"] = digitalRead(HEATER_RELAY) ? "ON" : "OFF";
  control["exhaust"] = digitalRead(EXHAUST_RELAY) ? "ON" : "OFF";
  
  String payload;
  serializeJson(doc, payload);
  
  int httpResponseCode = http.POST(payload);
  if (httpResponseCode != 200 && httpResponseCode != 201) {
    Serial.printf("[DEVICE API] Stream failed - HTTP %d\n", httpResponseCode);
  } else {
    Serial.println("[DEVICE API] Sensor data sent to backend");
  }
  
  http.end();
}

void checkAndExecuteRemoteCommands() {
  if (!wifiConnected || strlen(DEVICE_SERIAL) == 0 || strlen(DEVICE_API_KEY) == 0) {
    return;
  }
  
  char controlUrl[256];
  sprintf(controlUrl, "%s/%s", CONTROL_URL, DEVICE_SERIAL);
  
  HTTPClient http;
  http.begin(controlUrl);
  http.addHeader("x-device-serial", DEVICE_SERIAL);
  http.addHeader("x-api-key", DEVICE_API_KEY);
  http.setTimeout(5000);
  
  int httpResponseCode = http.GET();
  
  if (httpResponseCode == 200) {
    String response = http.getString();
    
    StaticJsonDocument<256> doc;
    DeserializationError error = deserializeJson(doc, response);
    
    if (!error && doc.containsKey("commands")) {
      JsonArray commands = doc["commands"].as<JsonArray>();
      
      for (JsonObject cmd : commands) {
        String commandType = cmd["type"].as<String>();
        String action = cmd["action"].as<String>();
        
        Serial.printf("[DEVICE API] Executing command: %s -> %s\n", commandType.c_str(), action.c_str());
        
        if (commandType == "heater") {
          if (action == "ON") {
            digitalWrite(HEATER_RELAY, HIGH);
            Serial.println("[DEVICE API] Heater turned ON (remote command)");
          } else if (action == "OFF") {
            digitalWrite(HEATER_RELAY, LOW);
            Serial.println("[DEVICE API] Heater turned OFF (remote command)");
          }
        }
        else if (commandType == "exhaust") {
          if (action == "ON") {
            digitalWrite(EXHAUST_RELAY, HIGH);
            Serial.println("[DEVICE API] Exhaust turned ON (remote command)");
          } else if (action == "OFF") {
            digitalWrite(EXHAUST_RELAY, LOW);
            Serial.println("[DEVICE API] Exhaust turned OFF (remote command)");
          }
        }
        else if (commandType == "solar") {
          if (action == "ON") {
            digitalWrite(SOLAR_RELAY, HIGH);
            Serial.println("[DEVICE API] Solar relay turned ON");
          } else if (action == "OFF") {
            digitalWrite(SOLAR_RELAY, LOW);
            Serial.println("[DEVICE API] Solar relay turned OFF");
          }
        }
        else if (commandType == "grid") {
          if (action == "ON") {
            digitalWrite(GRID_RELAY, HIGH);
            Serial.println("[DEVICE API] Grid relay turned ON");
          } else if (action == "OFF") {
            digitalWrite(GRID_RELAY, LOW);
            Serial.println("[DEVICE API] Grid relay turned OFF");
          }
        }
      }
    }
  }
  
  http.end();
}

// ================= SETUP =================
void setup() {
  Serial.begin(115200);
  
  // Initialize GSM
  gsm.begin(9600, SERIAL_8N1, GSM_RX, GSM_TX);
  delay(1000);
  initializeGSM();
  
  // Initialize EEPROM
  EEPROM.begin(EEPROM_SIZE);
  
  // Setup hardware
  setupHardware();
  initializeSensors();
  loadFromEEPROM();
  
  // Initialize EEPROM and load device credentials
  EEPROM.begin(EEPROM_SIZE);
  loadDeviceCredentialsFromEEPROM();
  
  // Try to register device if not already registered
  if (!deviceRegistered && wifiConnected) {
    registerDevice();
  }
  
  systemStartTime = millis();
  lastWatchdogReset = millis();
  
  Serial.println("\n=========================================");
  Serial.println("SOLAR POULTRY MONITORING SYSTEM v3.0");
  Serial.println("=========================================");
  printSystemStatus();
  
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("System Ready!");
  lcd.setCursor(0, 1);
  lcd.print("Monitoring...");
  delay(2000);
  
  sendGSMAlert("SYSTEM STARTED - Solar Poultry Monitor", "INFO");
}

void setupHardware() {
  // Initialize pins
  pinMode(BUZZER_PIN, OUTPUT);
  digitalWrite(BUZZER_PIN, HIGH);
  
  // Initialize I2C
  Wire.begin(I2C_SDA, I2C_SCL);
  Wire.setClock(100000);
  
  // Initialize LCD
  lcd.begin();
  lcd.backlight();
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Initializing...");
  
  // Connect to WiFi
  lcd.setCursor(0, 1);
  lcd.print("WiFi Connecting...");
  
  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  int wifiAttempts = 0;
  while (WiFi.status() != WL_CONNECTED && wifiAttempts < 25) {
    delay(500);
    Serial.print(".");
    wifiAttempts++;
    lcd.setCursor(0, 2);
    lcd.print("Attempt: ");
    lcd.print(wifiAttempts);
  }
  
  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\nWiFi connected!");
    Serial.print("IP: ");
    Serial.println(WiFi.localIP());
    lcd.setCursor(0, 2);
    lcd.print("WiFi: Connected  ");
  } else {
    Serial.println("\nWiFi connection failed!");
    lcd.setCursor(0, 2);
    lcd.print("WiFi: FAILED    ");
    sendGSMAlert("WiFi connection FAILED", "WARNING");
  }
  
  lcd.setCursor(0, 3);
  lcd.print("Sensors Warming..");
}

void initializeSensors() {
  Serial.println("\nInitializing sensors...");
  
  // Initialize DHT22
  dht.begin();
  delay(100);
  
  float testTemp = dht.readTemperature();
  if (isnan(testTemp)) {
    Serial.println("WARNING: DHT22 not responding");
    sensorErrors.dht22_error = true;
  } else {
    Serial.println("DHT22 OK");
    sensorErrors.dht22_error = false;
  }
  
  // Initialize DS18B20
  ds18b20.begin();
  if (ds18b20.getDeviceCount() == 0) {
    Serial.println("WARNING: DS18B20 not found");
    sensorErrors.ds18b20_error = true;
  } else {
    Serial.printf("DS18B20 OK - %d device(s)\n", ds18b20.getDeviceCount());
    sensorErrors.ds18b20_error = false;
  }
  
  // Initialize INA219
  initializeINA219();
  
  // Initialize gas sensors
  initializeGasSensors();
}

void initializeINA219() {
  if (!inaSolar.begin()) {
    Serial.println("ERROR: INA219 Solar sensor not found!");
    sensorErrors.ina219_solar_error = true;
    sendGSMAlert("SOLAR SENSOR FAILURE", "CRITICAL");
  } else {
    inaSolar.setCalibration_32V_2A();
    Serial.println("INA219 Solar sensor OK");
    sensorErrors.ina219_solar_error = false;
  }
  
  if (!inaLoad.begin()) {
    Serial.println("ERROR: INA219 Load sensor not found!");
    sensorErrors.ina219_load_error = true;
    sendGSMAlert("LOAD SENSOR FAILURE", "CRITICAL");
  } else {
    inaLoad.setCalibration_32V_2A();
    Serial.println("INA219 Load sensor OK");
    sensorErrors.ina219_load_error = false;
  }
}

void initializeGasSensors() {
  pinMode(MG811_PIN, INPUT);
  pinMode(MQ137_PIN, INPUT);
  pinMode(MQ9_PIN, INPUT);
  pinMode(LDR_IN_PIN, INPUT);
  pinMode(LDR_OUT_PIN, INPUT);
  
  Serial.println("Gas sensors warming up (60 seconds)...");
  gasSensorWarmupStart = millis();
  gasSensorsInitialized = true;
}

void initializeGSM() {
  Serial.println("Initializing GSM module...");
  
  // Test GSM response
  gsm.println("AT");
  delay(500);
  
  if (!gsm.available()) {
    Serial.println("WARNING: GSM module not responding!");
    return;
  }
  
  // Clear buffer
  while(gsm.available()) gsm.read();
  
  // Set SMS text mode
  gsm.println("AT+CMGF=1");
  delay(200);
  
  // Disable echo
  gsm.println("ATE0");
  delay(200);
  
  Serial.println("GSM module ready");
}

bool isGasSensorsReady() {
  if (!gasSensorsInitialized) return false;
  
  if (!gasSensorsReady) {
    unsigned long elapsed = millis() - gasSensorWarmupStart;
    if (elapsed >= 60000) {
      gasSensorsReady = true;
      Serial.println("Gas sensors ready!");
      sendGSMAlert("Gas sensors ready - monitoring active", "INFO");
      return true;
    }
  }
  return gasSensorsReady;
}

// ================= PIN CONNECTION CHECK =================

void checkAllPinConnections() {
  pinConnection.mg811_connected = isPinConnected(MG811_PIN);
  pinConnection.mq137_connected = isPinConnected(MQ137_PIN);
  pinConnection.mq9_connected = isPinConnected(MQ9_PIN);
  pinConnection.ldr_in_connected = isPinConnected(LDR_IN_PIN);
  pinConnection.ldr_out_connected = isPinConnected(LDR_OUT_PIN);
  
  static bool lastStatus[5] = {false};
  bool currentStatus[5] = {
    pinConnection.mg811_connected,
    pinConnection.mq137_connected,
    pinConnection.mq9_connected,
    pinConnection.ldr_in_connected,
    pinConnection.ldr_out_connected
  };
  
  const char* sensorNames[5] = {"CO2", "NH3", "Methane", "LDR Inside", "LDR Outside"};
  
  for(int i = 0; i < 5; i++) {
    if(currentStatus[i] && !lastStatus[i]) {
      Serial.printf("✅ Sensor %s now connected!\n", sensorNames[i]);
      sendGSMAlert(String(sensorNames[i]) + " sensor connected", "INFO");
    }
    else if(!currentStatus[i] && lastStatus[i]) {
      Serial.printf("❌ Sensor %s disconnected!\n", sensorNames[i]);
      sendGSMAlert(String(sensorNames[i]) + " sensor DISCONNECTED", "WARNING");
    }
    lastStatus[i] = currentStatus[i];
  }
}

bool isPinConnected(int pin) {
  int reading = analogRead(pin);
  return (reading > 10 && reading < 4000);
}

// Manual watchdog reset - simple delay based approach
void resetWatchdog() {
  // Simple feed mechanism - just update timestamp
  // ESP32 will reset if loop takes too long
  if (millis() - lastWatchdogReset > 25000) {
    lastWatchdogReset = millis();
    Serial.println("Watchdog reset");
  }
}

// ================= MAIN LOOP =================
void loop() {
  // Simple software watchdog - reset every loop iteration
  resetWatchdog();
  
  unsigned long currentMillis = millis();
  
  // Read sensors every 5 seconds
  if (currentMillis - lastSensorRead >= 5000) {
    lastSensorRead = currentMillis;
    readEnvironmentalSensors();
    readPowerSensors();
    determinePowerSource();
    calculateEnergyAndCost();
  }
  
  // Update LCD every 2 seconds
  if (currentMillis - lastLCDUpdate >= 2000) {
    lastLCDUpdate = currentMillis;
    updateLCD();
  }
  
  // Send data every 30 seconds
  if (currentMillis - lastSendMillis >= 30000) {
    lastSendMillis = currentMillis;
    sendDataToBackend();
  }
  
  // Check alerts every 10 seconds
  if (currentMillis - lastAlertCheck >= 10000) {
    lastAlertCheck = currentMillis;
    checkAlerts();
  }
  
  // Check WiFi every 60 seconds
  if (currentMillis - lastGSMCheck >= 60000) {
    lastGSMCheck = currentMillis;
    checkWiFiAndReconnect();
    checkAllPinConnections();
  }
  
  // Device Registration (if not registered, try every 30 seconds after WiFi connects)
  if (!deviceRegistered && wifiConnected && (currentMillis - lastRegistrationAttempt >= 30000)) {
    lastRegistrationAttempt = currentMillis;
    registerDevice();
  }
  
  // Send device status every 120 seconds (2 minutes)
  if (deviceRegistered && (currentMillis - lastStatusUpdate >= 120000)) {
    lastStatusUpdate = currentMillis;
    updateDeviceStatus();
  }
  
  // Send sensor data to API every 30 seconds
  if (deviceRegistered && (currentMillis - lastSensorStream >= 30000)) {
    lastSensorStream = currentMillis;
    sendSensorDataToAPI();
  }
  
  // Check for remote commands every 60 seconds
  if (deviceRegistered && (currentMillis - lastCommandCheck >= 60000)) {
    lastCommandCheck = currentMillis;
    checkAndExecuteRemoteCommands();
  }
  
  // Save to EEPROM every hour
  if (currentMillis - lastEnergyCalc >= 3600000) {
    lastEnergyCalc = currentMillis;
    saveToEEPROM();
  }
  
  // System health check every 6 hours
  static unsigned long lastHealthCheck = 0;
  if (currentMillis - lastHealthCheck >= 21600000) {
    lastHealthCheck = currentMillis;
    systemHealthCheck();
  }
  
  delay(50);
}

// ================= SENSOR READING FUNCTIONS =================

void readEnvironmentalSensors() {
  // DHT22 Reading with Retry Logic
  int dhtRetries = 0;
  const int MAX_DHT_RETRIES = 3;
  
  while (dhtRetries < MAX_DHT_RETRIES) {
    temp = dht.readTemperature();
    hum = dht.readHumidity();
    
    if (!isnan(temp) && !isnan(hum) && temp > -40 && temp < 85 && hum >= 0 && hum <= 100) {
      sensorErrors.dht22_error = false;
      consecutiveDHTErrors = 0;
      break;
    }
    
    dhtRetries++;
    consecutiveDHTErrors++;
    delay(200);
    
    if (dhtRetries >= MAX_DHT_RETRIES) {
      sensorErrors.dht22_error = true;
      Serial.println("DHT22 ERROR: Failed after 3 retries");
      
      if (consecutiveDHTErrors >= 10) {
        dht.begin();
        delay(1000);
        consecutiveDHTErrors = 0;
      }
    }
  }
  
  // DS18B20 Temperature
  ds18b20.requestTemperatures();
  insideTemp = ds18b20.getTempCByIndex(0);
  
  if (insideTemp == DEVICE_DISCONNECTED_C || insideTemp > 125 || insideTemp < -55) {
    sensorErrors.ds18b20_error = true;
    insideTemp = -999;
  } else {
    sensorErrors.ds18b20_error = false;
  }
  
  // LDR Readings
  ldr_inside = analogRead(LDR_IN_PIN);
  ldr_outside = analogRead(LDR_OUT_PIN);
  
  // Gas Sensors with Warm-up Check
  if (isGasSensorsReady()) {
    if (pinConnection.mg811_connected) {
      co2_level = readCO2();
      sensorErrors.co2_error = (co2_level < 300 || co2_level > 5000);
    } else {
      co2_level = -1;
    }
    
    if (pinConnection.mq137_connected) {
      ammonia_level = readAmmonia();
      sensorErrors.nh3_error = (ammonia_level < 0 || ammonia_level > 100);
    } else {
      ammonia_level = -1;
    }
    
    if (pinConnection.mq9_connected) {
      methane_level = readMethane();
    } else {
      methane_level = -1;
    }
  } else {
    co2_level = -1;
    ammonia_level = -1;
    methane_level = -1;
    
    static unsigned long lastWarmupMsg = 0;
    if (millis() - lastWarmupMsg > 10000 && !gasSensorsReady) {
      lastWarmupMsg = millis();
      int secondsLeft = 60 - ((millis() - gasSensorWarmupStart) / 1000);
      if (secondsLeft > 0) {
        Serial.printf("Gas warmup: %d seconds remaining\n", secondsLeft);
      }
    }
  }
  
  // Report errors periodically
  if (millis() - lastErrorReport > 60000) {
    if (sensorErrors.dht22_error || sensorErrors.co2_error || 
        sensorErrors.nh3_error || sensorErrors.ds18b20_error) {
      
      String errorMsg = "Sensor errors: ";
      if (sensorErrors.dht22_error) errorMsg += "DHT22 ";
      if (sensorErrors.ds18b20_error) errorMsg += "DS18B20 ";
      if (sensorErrors.co2_error) errorMsg += "CO2 ";
      if (sensorErrors.nh3_error) errorMsg += "NH3 ";
      
      Serial.println(errorMsg);
      
      static unsigned long lastErrorSMS = 0;
      if (millis() - lastErrorSMS > 3600000) {
        sendGSMAlert(errorMsg, "WARNING");
        lastErrorSMS = millis();
      }
    }
    lastErrorReport = millis();
  }
}

float readCO2() {
  int adcValue = analogRead(MG811_PIN);
  float voltage = adcValue * (3.3 / 4095.0);
  float co2_ppm = 400.0 * (voltage / CO2_VOLTAGE_CLEAN_AIR);
  co2_ppm = constrain(co2_ppm, 300, 5000);
  return co2_ppm;
}

float readAmmonia() {
  int adcValue = analogRead(MQ137_PIN);
  float voltage = adcValue * (3.3 / 4095.0);
  float nh3_ppm = 50.0 * (voltage / NH3_VOLTAGE_CLEAN_AIR);
  nh3_ppm = constrain(nh3_ppm, 0, 100);
  return nh3_ppm;
}

float readMethane() {
  int adcValue = analogRead(MQ9_PIN);
  float methane_ppm = adcValue * (1000.0 / 4095.0);
  return methane_ppm;
}

void readPowerSensors() {
  if (!sensorErrors.ina219_solar_error) {
    solarVoltage = inaSolar.getBusVoltage_V();
    solarCurrent = inaSolar.getCurrent_mA() / 1000.0;
    solarPower = inaSolar.getPower_mW() / 1000.0;
    
    if (isnan(solarPower) || solarPower < 0) solarPower = 0;
    if (isnan(solarVoltage)) solarVoltage = 0;
    if (isnan(solarCurrent)) solarCurrent = 0;
  } else {
    solarVoltage = 0;
    solarCurrent = 0;
    solarPower = 0;
  }
  
  if (!sensorErrors.ina219_load_error) {
    loadVoltage = inaLoad.getBusVoltage_V();
    loadCurrent = inaLoad.getCurrent_mA() / 1000.0;
    loadPower = inaLoad.getPower_mW() / 1000.0;
    
    if (isnan(loadPower) || loadPower < 0) loadPower = 0;
    if (isnan(loadVoltage)) loadVoltage = 0;
    if (isnan(loadCurrent)) loadCurrent = 0;
  } else {
    loadVoltage = 0;
    loadCurrent = 0;
    loadPower = 0;
  }
  
  if (loadVoltage > 0) {
    batteryVoltage = loadVoltage;
  }
}

// ================= POWER MANAGEMENT =================

void determinePowerSource() {
  if (solarPower >= LOW_SOLAR_THRESHOLD && solarVoltage >= 12.0) {
    currentSource = "SOLAR";
    systemStatus = "NORMAL";
  } 
  else if (batteryVoltage >= BATTERY_LOW_VOLTAGE && batteryVoltage > 0) {
    currentSource = "BATTERY";
    systemStatus = "NORMAL";
  }
  else if (batteryVoltage > 0 && batteryVoltage < BATTERY_LOW_VOLTAGE) {
    currentSource = "BATTERY";
    systemStatus = "LOW_BATTERY";
  }
  else {
    currentSource = "GRID";
    systemStatus = (loadPower > 0.1) ? "ON_GRID" : "POWER_OUTAGE";
  }
  
  static String lastSource = "";
  if (lastSource != currentSource) {
    Serial.printf("Source changed: %s -> %s\n", lastSource.c_str(), currentSource.c_str());
    sendGSMAlert("Power source: " + currentSource, "INFO");
    lastSource = currentSource;
  }
}

void calculateEnergyAndCost() {
  unsigned long now = millis();
  static unsigned long lastCalculation = 0;
  
  if (lastCalculation == 0) {
    lastCalculation = now;
    return;
  }
  
  float deltaHours = (now - lastCalculation) / 3600000.0;
  
  // Cap maximum delta to prevent spikes
  if (deltaHours > 0.1) {
    deltaHours = 0.01667;
  }
  
  lastCalculation = now;
  
  if (currentSource == "GRID") {
    float energyUsed = (loadPower * deltaHours) / 1000.0;
    
    if (energyUsed > 0 && energyUsed < 100) {
      gridEnergy_kWh += energyUsed;
      dailyEnergy_kWh += energyUsed;
      totalCost_RWF = gridEnergy_kWh * TARIFF_RWF;
      dailyCost_RWF = dailyEnergy_kWh * TARIFF_RWF;
    }
  }
  
  static unsigned long lastDailyReset = 0;
  if (now - lastDailyReset >= 86400000) {
    Serial.println("Resetting daily counters...");
    dailyEnergy_kWh = 0;
    dailyCost_RWF = 0;
    lastDailyReset = now;
    saveToEEPROM();
    
    String summary = "Daily Summary: Saved " + String(dailyEnergy_kWh, 1) + 
                     "kWh, Cost: " + String(dailyCost_RWF, 0) + " RWF";
    sendGSMAlert(summary, "INFO");
  }
}

// ================= DISPLAY FUNCTIONS =================

void updateLCD() {
  lcd.clear();
  
  // Line 1: Voltage and Source
  lcd.setCursor(0, 0);
  lcd.print("V:");
  if (currentSource == "SOLAR") {
    lcd.print(solarVoltage, 1);
  } else {
    lcd.print(loadVoltage, 1);
  }
  lcd.print("V ");
  
  if (currentSource == "SOLAR") {
    lcd.print("SOLAR");
  } else if (currentSource == "BATTERY") {
    lcd.print("BAT");
  } else {
    lcd.print("GRID");
  }
  
  if (sensorErrors.dht22_error || sensorErrors.co2_error || sensorErrors.nh3_error) {
    lcd.setCursor(19, 0);
    lcd.print("!");
  }
  
  // Line 2: Solar and Load Power
  lcd.setCursor(0, 1);
  lcd.print("S:");
  lcd.print(solarPower, 1);
  lcd.print("W L:");
  lcd.print(loadPower, 1);
  lcd.print("W");
  
  // Line 3: Temperature and Humidity
  lcd.setCursor(0, 2);
  if (!sensorErrors.dht22_error && temp != -999) {
    lcd.print("T:");
    lcd.print(temp, 1);
    lcd.print("C");
    lcd.setCursor(8, 2);
    lcd.print("H:");
    lcd.print(hum, 1);
    lcd.print("%");
  } else {
    lcd.print("DHT22 ERROR");
  }
  
  // Line 4: Energy or Gas Levels
  lcd.setCursor(0, 3);
  if (currentSource == "GRID") {
    lcd.print("Cost:");
    lcd.print(totalCost_RWF, 0);
    lcd.print(" RWF");
  } else if (gasSensorsReady && co2_level > 0) {
    lcd.print("CO2:");
    lcd.print(co2_level, 0);
    lcd.print(" NH3:");
    lcd.print(ammonia_level, 0);
  } else {
    lcd.print("Saved:");
    lcd.print(dailyEnergy_kWh, 2);
    lcd.print("kWh");
  }
}

// ================= COMMUNICATION FUNCTIONS =================

void sendDataToBackend() {
  if (sensorErrors.dht22_error && sensorErrors.ina219_load_error && 
      sensorErrors.ina219_solar_error) {
    Serial.println("Too many errors - skipping update");
    return;
  }
  
  if (WiFi.status() != WL_CONNECTED) {
    if (!wifiAlertSent) {
      sendGSMAlert("WiFi LOST - Using GSM backup", "WARNING");
      wifiAlertSent = true;
    }
    sendGSMBackup();
    return;
  }
  
  wifiAlertSent = false;
  
  HTTPClient http;
  http.begin(serverURL);
  http.addHeader("Content-Type", "application/json");
  http.setTimeout(5000);
  
  StaticJsonDocument<1024> doc;
  doc["serialNumber"] = deviceSerialNumber;
  doc["timestamp"] = millis();
  doc["systemStatus"] = systemStatus;
  doc["uptime_hours"] = (millis() - systemStartTime) / 3600000.0;
  
  JsonObject env = doc.createNestedObject("environment");
  env["temperature"] = (temp > -999) ? temp : -999;
  env["humidity"] = hum;
  env["inside_temp"] = insideTemp;
  env["co2_ppm"] = co2_level;
  env["ammonia_ppm"] = ammonia_level;
  env["methane_ppm"] = methane_level;
  env["light_inside"] = ldr_inside;
  env["light_outside"] = ldr_outside;
  
  JsonObject power = doc.createNestedObject("power");
  power["solar_voltage"] = solarVoltage;
  power["solar_current"] = solarCurrent;
  power["solar_power"] = solarPower;
  power["load_voltage"] = loadVoltage;
  power["load_current"] = loadCurrent;
  power["load_power"] = loadPower;
  power["battery_voltage"] = batteryVoltage;
  power["source"] = currentSource;
  
  JsonObject energy = doc.createNestedObject("energy");
  energy["grid_energy_total_kwh"] = gridEnergy_kWh;
  energy["grid_energy_daily_kwh"] = dailyEnergy_kWh;
  energy["total_cost_rwf"] = totalCost_RWF;
  energy["daily_cost_rwf"] = dailyCost_RWF;
  energy["tariff_rwf_per_kwh"] = TARIFF_RWF;
  
  JsonObject errors = doc.createNestedObject("sensor_errors");
  errors["dht22"] = sensorErrors.dht22_error;
  errors["ds18b20"] = sensorErrors.ds18b20_error;
  errors["co2"] = sensorErrors.co2_error;
  errors["nh3"] = sensorErrors.nh3_error;
  errors["ina219_solar"] = sensorErrors.ina219_solar_error;
  errors["ina219_load"] = sensorErrors.ina219_load_error;
  
  String payload;
  serializeJson(doc, payload);
  
  int httpResponseCode = http.POST(payload);
  
  if (httpResponseCode > 0) {
    Serial.printf("Data sent. Response: %d\n", httpResponseCode);
    systemStatus = "NORMAL";
  } else {
    Serial.printf("HTTP error: %d\n", httpResponseCode);
    systemStatus = "COMMS_ERROR";
  }
  
  http.end();
}

void sendGSMBackup() {
  String message = "BACKUP: T:" + String(temp, 1) + "C ";
  message += "L:" + String(loadPower, 0) + "W ";
  message += "Src:" + currentSource;
  message += " Cost:" + String(totalCost_RWF, 0);
  sendGSMAlert(message, "CRITICAL");
}

void sendGSMAlert(String message, String priority) {
  gsm.println("AT");
  delay(500);
  
  if (!gsm.available()) {
    Serial.println("GSM not responding!");
    return;
  }
  
  while(gsm.available()) gsm.read();
  
  gsm.println("AT+CMGF=1");
  delay(200);
  
  gsm.print("AT+CMGS=\"");
  gsm.print(PHONE_1);
  gsm.println("\"");
  delay(200);
  
  gsm.print("[");
  gsm.print(priority);
  gsm.print("] ");
  gsm.print(deviceSerialNumber);
  gsm.print(": ");
  gsm.println(message);
  gsm.write(26);
  delay(3000);
  
  if (priority == "CRITICAL") {
    gsm.print("AT+CMGS=\"");
    gsm.print(PHONE_2);
    gsm.println("\"");
    delay(200);
    gsm.print("[CRITICAL] ");
    gsm.print(deviceSerialNumber);
    gsm.print(": ");
    gsm.println(message);
    gsm.write(26);
    delay(3000);
  }
  
  if (priority == "CRITICAL") {
    for (int i = 0; i < 3; i++) {
      digitalWrite(BUZZER_PIN, LOW);
      delay(200);
      digitalWrite(BUZZER_PIN, HIGH);
      delay(100);
    }
  }
  
  Serial.println("SMS sent: " + message);
}

// ================= ALERT AND MONITORING =================

void checkAlerts() {
  // Low battery alert
  if (batteryVoltage > 0 && batteryVoltage < BATTERY_LOW_VOLTAGE && !lowVoltageAlertSent) {
    sendGSMAlert("BATTERY LOW: " + String(batteryVoltage, 1) + "V", "WARNING");
    lowVoltageAlertSent = true;
  } else if (batteryVoltage >= BATTERY_LOW_VOLTAGE) {
    lowVoltageAlertSent = false;
  }
  
  // Critical battery
  if (batteryVoltage > 0 && batteryVoltage < BATTERY_CRITICAL_VOLTAGE) {
    sendGSMAlert("CRITICAL BATTERY! System may fail", "CRITICAL");
    digitalWrite(BUZZER_PIN, LOW);
    delay(500);
    digitalWrite(BUZZER_PIN, HIGH);
  }
  
  // Overload alert
  if (loadPower > OVERLOAD_THRESHOLD && !overloadAlertSent) {
    sendGSMAlert("OVERLOAD: " + String(loadPower, 0) + "W", "CRITICAL");
    overloadAlertSent = true;
  } else if (loadPower <= OVERLOAD_THRESHOLD * 0.8) {
    overloadAlertSent = false;
  }
  
  // High temperature alert
  if ((temp > HIGH_TEMP_THRESHOLD || insideTemp > HIGH_TEMP_THRESHOLD) && !highTempAlertSent) {
    String alertMsg = "HIGH TEMP: Outside " + String(temp, 1) + "C, Inside " + String(insideTemp, 1) + "C";
    sendGSMAlert(alertMsg, "WARNING");
    highTempAlertSent = true;
  } else if (temp <= HIGH_TEMP_THRESHOLD - 2 && insideTemp <= HIGH_TEMP_THRESHOLD - 2) {
    highTempAlertSent = false;
  }
  
  // Gas alerts
  if (gasSensorsReady) {
    if ((co2_level > HIGH_CO2_THRESHOLD || ammonia_level > HIGH_NH3_THRESHOLD) && !gasSensorAlertSent) {
      String gasMsg = "Gas high - CO2:" + String(co2_level, 0) + 
                      "ppm NH3:" + String(ammonia_level, 1) + "ppm";
      sendGSMAlert(gasMsg, "WARNING");
      gasSensorAlertSent = true;
      
      for (int i = 0; i < 5; i++) {
        digitalWrite(BUZZER_PIN, LOW);
        delay(100);
        digitalWrite(BUZZER_PIN, HIGH);
        delay(100);
      }
    } else if (co2_level < HIGH_CO2_THRESHOLD * 0.7 && ammonia_level < HIGH_NH3_THRESHOLD * 0.7) {
      gasSensorAlertSent = false;
    }
  }
}

void checkWiFiAndReconnect() {
  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("WiFi disconnected. Reconnecting...");
    WiFi.disconnect();
    WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
    
    int attempts = 0;
    while (WiFi.status() != WL_CONNECTED && attempts < 30) {
      delay(1000);
      attempts++;
      Serial.print(".");
    }
    
    if (WiFi.status() == WL_CONNECTED) {
      Serial.println("\nWiFi reconnected!");
      sendGSMAlert("WiFi RECONNECTED", "INFO");
    } else {
      Serial.println("\nWiFi reconnection failed!");
    }
  }
}

void systemHealthCheck() {
  String healthReport = "HEALTH - Uptime:" + String((millis() - systemStartTime) / 3600000) + "h ";
  healthReport += "WiFi:" + String(WiFi.status() == WL_CONNECTED ? "OK" : "DOWN") + " ";
  healthReport += "Solar:" + String(solarPower, 0) + "W ";
  healthReport += "Load:" + String(loadPower, 0) + "W ";
  healthReport += "Saved:" + String(dailyEnergy_kWh, 1) + "kWh";
  
  Serial.println(healthReport);
  sendGSMAlert(healthReport, "INFO");
}

// ================= DATA PERSISTENCE =================

void saveToEEPROM() {
  Serial.println("Saving to EEPROM...");
  
  int address = 0;
  EEPROM.put(address, EEPROM_MAGIC);
  address += sizeof(EEPROM_MAGIC);
  
  EEPROM.put(address, gridEnergy_kWh);
  address += sizeof(gridEnergy_kWh);
  
  EEPROM.put(address, totalCost_RWF);
  address += sizeof(totalCost_RWF);
  
  EEPROM.put(address, dailyEnergy_kWh);
  address += sizeof(dailyEnergy_kWh);
  
  EEPROM.put(address, dailyCost_RWF);
  address += sizeof(dailyCost_RWF);
  
  EEPROM.put(address, millis());
  
  if (EEPROM.commit()) {
    Serial.printf("Saved: Grid %.2f kWh, Cost %.2f RWF\n", gridEnergy_kWh, totalCost_RWF);
  } else {
    Serial.println("EEPROM write failed!");
  }
}

void loadFromEEPROM() {
  Serial.println("Loading from EEPROM...");
  
  int address = 0;
  uint16_t magic;
  
  EEPROM.get(address, magic);
  address += sizeof(magic);
  
  if (magic == EEPROM_MAGIC) {
    EEPROM.get(address, gridEnergy_kWh);
    address += sizeof(gridEnergy_kWh);
    
    EEPROM.get(address, totalCost_RWF);
    address += sizeof(totalCost_RWF);
    
    EEPROM.get(address, dailyEnergy_kWh);
    address += sizeof(dailyEnergy_kWh);
    
    EEPROM.get(address, dailyCost_RWF);
    
    Serial.printf("Loaded: Grid %.2f kWh, Cost %.2f RWF\n", gridEnergy_kWh, totalCost_RWF);
  } else {
    Serial.println("No saved data - initializing");
    gridEnergy_kWh = 0.0;
    totalCost_RWF = 0.0;
    dailyEnergy_kWh = 0.0;
    dailyCost_RWF = 0.0;
    saveToEEPROM();
  }
}

void printSystemStatus() {
  Serial.println("\n--- SYSTEM STATUS ---");
  Serial.printf("Device: %s\n", deviceSerialNumber);
  Serial.printf("WiFi: %s\n", WiFi.status() == WL_CONNECTED ? "Connected" : "Disconnected");
  if (WiFi.status() == WL_CONNECTED) {
    Serial.printf("IP: %s\n", WiFi.localIP().toString().c_str());
  }
  Serial.printf("Uptime: %lu hours\n", (millis() - systemStartTime) / 3600000);
  
  Serial.println("\nSensor Status:");
  Serial.printf("  DHT22: %s\n", sensorErrors.dht22_error ? "ERROR" : "OK");
  Serial.printf("  DS18B20: %s\n", sensorErrors.ds18b20_error ? "ERROR" : "OK");
  Serial.printf("  INA219 Solar: %s\n", sensorErrors.ina219_solar_error ? "ERROR" : "OK");
  Serial.printf("  INA219 Load: %s\n", sensorErrors.ina219_load_error ? "ERROR" : "OK");
  Serial.printf("  Gas Sensors: %s\n", gasSensorsReady ? "Ready" : "Warming up");
  
  Serial.println("\nPin Connections:");
  Serial.printf("  CO2 Sensor (GPIO34): %s\n", pinConnection.mg811_connected ? "✅ Connected" : "❌ Not Connected");
  Serial.printf("  NH3 Sensor (GPIO35): %s\n", pinConnection.mq137_connected ? "✅ Connected" : "❌ Not Connected");
  Serial.printf("  Methane Sensor (GPIO32): %s\n", pinConnection.mq9_connected ? "✅ Connected" : "❌ Not Connected");
  Serial.printf("  LDR Inside (GPIO33): %s\n", pinConnection.ldr_in_connected ? "✅ Connected" : "❌ Not Connected");
  Serial.printf("  LDR Outside (GPIO25): %s\n", pinConnection.ldr_out_connected ? "✅ Connected" : "❌ Not Connected");
  
  Serial.println("----------------------\n");
}