const char* WIFI_PASSWORD = "12345678";
const char* BACKEND_URL = "http://192.168.137.1:5000";
const char* REGISTER_URL = "http://192.168.137.1:5000/api/devices/register";
const char* STATUS_URL = "http://192.168.137.1:5000/api/devices/status";
const char* STREAM_URL = "http://192.168.137.1:5000/api/predictions/stream";
const char* CONTROL_URL = "http://192.168.137.1:5000/api/predictions/control";

// Sensor Objects
