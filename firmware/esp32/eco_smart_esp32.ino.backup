// ================= PIN CONFIGURATION =================
// Environmental Sensors (Using ADC1 pins for WiFi compatibility)
#define DHTPIN          15    // DHT22 Temperature/Humidity
#define ONE_WIRE_BUS    14    // DS18B20 Temperature sensor
#define BUZZER_PIN      13    // Active LOW buzzer

// Gas Sensors (ADC1 pins - compatible with WiFi)
#define MG811_PIN       34    // CO2 Sensor (ADC1)
#define MQ137_PIN       35    // NH3/Ammonia Sensor (ADC1)
#define MQ9_PIN         32    // Methane/CO Sensor (ADC1)
#define LDR_IN_PIN      33    // Inside light sensor (ADC1)
#define LDR_OUT_PIN     25    // Outside light sensor (ADC1)

// I2C Configuration
#define I2C_SDA         21
#define I2C_SCL         22

// INA219 Addresses
#define INA219_ADDRESS_SOLAR 0x40
#define INA219_ADDRESS_LOAD  0x41

// EEPROM Configuration
#define EEPROM_SIZE            512
#define EEPROM_MAGIC           0xA5F0
#define EEPROM_DEVICE_SERIAL_ADDR   0
#define EEPROM_DEVICE_API_KEY_ADDR  32
#define EEPROM_SERIAL_LENGTH   16  // e.g., "NT-XX-TCL"
#define EEPROM_API_KEY_LENGTH  48

// Device Credentials (loaded from EEPROM)
char DEVICE_SERIAL[EEPROM_SERIAL_LENGTH] = "";
char DEVICE_API_KEY[EEPROM_API_KEY_LENGTH] = "";
bool deviceRegistered = false;

// LCD Configuration
LiquidCrystal_I2C lcd(0x27, 20, 4);

// GSM Configuration
HardwareSerial gsm(2);
#define GSM_RX 16
#define GSM_TX 17

